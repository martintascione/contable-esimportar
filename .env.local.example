# ============================================================
# Contable IA — Variables de entorno
# Copiá este archivo como .env.local y completá los valores.
# NO subas .env.local al repositorio.
# ============================================================

# ---- Supabase (requerido) ---------------------------------
# Tomado de tu proyecto en https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# service_role: SOLO server-side. Nunca exponer al browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- Anthropic Claude (requerido para el motor de IA) -----
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...
# Modelo por defecto para extracción de documentos
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- URL pública (opcional) -------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Integraciones opcionales (se pueden dejar vacías) ----
RESEND_API_KEY=
WHATSAPP_API_TOKEN=
MERCADOPAGO_ACCESS_TOKEN=
